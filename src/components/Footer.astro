---
import site from "../data/site.json";
import XfiLogo from "./XfiLogo.astro";
---

<footer class="border-t border-zinc-200 bg-white py-10">
  <div class="container-shell">
    <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:items-end sm:justify-between sm:text-left">
      <div class="flex items-center gap-4">
        <XfiLogo variant="primary" class="h-9 w-[62px]" alt="XFI" />
        <div>
        <p class="font-semibold text-zinc-950">{site.name}</p>
        <p class="mt-1 text-sm text-zinc-500">{site.tagline}</p>
        </div>
      </div>
      <a
        class="text-xs text-zinc-400 transition hover:text-zinc-700"
        href="https://trisf.my.id"
        target="_blank"
        rel="noreferrer"
      >
        Crafted by TRISF
      </a>
    </div>
  </div>
</footer>

---
import site from "../data/site.json";
import XfiLogo from "./XfiLogo.astro";
import { basePath } from "../utils/paths";
---

<footer class="border-t border-zinc-200 bg-white py-10">
  <div class="container-shell">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-4">
        <XfiLogo variant="primary" class="h-9 w-[62px]" alt="XFI" />
        <div>
        <p class="font-semibold text-zinc-950">{site.name}</p>
        <p class="mt-1 text-sm text-zinc-500">{site.tagline}</p>
        </div>
      </div>
      <nav class="flex flex-wrap gap-4 text-sm text-zinc-500">
        <a class="hover:text-zinc-950" href={`${basePath}campaigns/`}>Campaigns</a>
        <a class="hover:text-zinc-950" href={`${basePath}updates/`}>Updates</a>
        <a class="hover:text-zinc-950" href={site.telegramChannelUrl} target="_blank" rel="noreferrer">Telegram Channel</a>
        <a class="hover:text-zinc-950" href={site.telegramGroupUrl} target="_blank" rel="noreferrer">Telegram Group</a>
        <a class="hover:text-zinc-950" href={site.githubUrl} target="_blank" rel="noreferrer">GitHub Org</a>
      </nav>
    </div>
    <div class="mt-8 border-t border-zinc-100 pt-5 text-xs text-zinc-400">
      <a class="hover:text-zinc-700" href="https://trisf.my.id" target="_blank" rel="noreferrer">
        Crafted by TRISF
      </a>
    </div>
  </div>
</footer>

---
import site from "../data/site.json";
import XfiLogo from "./XfiLogo.astro";
import { basePath } from "../utils/paths";
---

<footer class="border-t border-zinc-200 bg-white py-10">
  <div class="container-shell flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-4">
      <XfiLogo variant="primary" class="h-9 w-[62px]" alt="XFI" />
      <div>
      <p class="font-semibold text-zinc-950">{site.name}</p>
      <p class="mt-1 text-sm text-zinc-500">{site.tagline}</p>
      </div>
    </div>
    <nav class="flex flex-wrap gap-4 text-sm text-zinc-500">
      <a class="hover:text-zinc-950" href={`${basePath}campaigns/`}>Campaigns</a>
      <a class="hover:text-zinc-950" href={`${basePath}updates/`}>Updates</a>
      <a class="hover:text-zinc-950" href={site.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
      <a class="hover:text-zinc-950" href={site.telegramUrl} target="_blank" rel="noreferrer">Telegram</a>
    </nav>
  </div>
</footer>

---
import site from "../data/site.json";
import XfiLogo from "./XfiLogo.astro";
import { basePath } from "../utils/paths";
const nav = [
  ["Home", basePath],
  ["Campaigns", `${basePath}campaigns/`],
  ["Updates", `${basePath}updates/`],
  ["About", `${basePath}about/`],
];
---

<header class="sticky top-0 z-30 border-b border-zinc-200/80 bg-white/88 backdrop-blur">
  <div class="container-shell flex min-h-16 items-center justify-between gap-4">
    <a href={basePath} class="focus-ring flex items-center gap-3 rounded-md text-sm font-semibold text-zinc-950">
      <XfiLogo variant="primary" class="h-8 w-[55px]" alt="XFI" />
      <span class="hidden sm:inline">{site.name}</span>
    </a>
    <nav class="hidden items-center gap-5 text-sm text-zinc-600 md:flex">
      {nav.map(([label, href]) => (
        <a class="focus-ring rounded-md hover:text-zinc-950" href={href}>{label}</a>
      ))}
      <a class="focus-ring rounded-md hover:text-zinc-950" href={site.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
      <a class="focus-ring rounded-md text-xiaomi hover:text-[#e95f00]" href={site.telegramUrl} target="_blank" rel="noreferrer">Telegram</a>
    </nav>
    <div class="flex gap-3 md:hidden">
      <a class="focus-ring rounded-md text-sm text-zinc-600" href={`${basePath}campaigns/`}>Campaigns</a>
      <a class="focus-ring rounded-md text-sm text-xiaomi" href={site.telegramUrl} target="_blank" rel="noreferrer">Telegram</a>
    </div>
  </div>
</header>

---
import site from "../data/site.json";
import XfiLogo from "./XfiLogo.astro";
import { basePath } from "../utils/paths";
const nav = [
  ["Home", basePath],
  ["Campaigns", `${basePath}campaigns/`],
  ["Updates", `${basePath}updates/`],
  ["About", `${basePath}about/`],
  ["Community", `${basePath}#community`],
];

const externalNav = [
  ["GitHub", site.githubUrl],
  ["Telegram Channel", site.telegramChannelUrl],
];
---

<header class="sticky top-0 z-30 border-b border-zinc-200/80 bg-white/88 backdrop-blur">
  <div class="container-shell flex min-h-16 items-center justify-between gap-4">
    <a href={basePath} class="focus-ring flex items-center rounded-md" aria-label={site.name}>
      <XfiLogo variant="primary" class="h-8 w-[55px]" alt="XFI" />
    </a>
    <nav class="hidden items-center gap-5 text-sm text-zinc-600 lg:flex">
      {nav.map(([label, href]) => (
        <a class="focus-ring rounded-md hover:text-zinc-950" href={href}>{label}</a>
      ))}
      <a class="focus-ring rounded-md hover:text-zinc-950" href={site.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
      <a class="focus-ring rounded-md text-xiaomi hover:text-[#e95f00]" href={site.telegramChannelUrl} target="_blank" rel="noreferrer">Telegram</a>
    </nav>
    <button
      class="focus-ring inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 bg-white text-zinc-700 shadow-sm lg:hidden"
      type="button"
      aria-label="Open navigation menu"
      aria-controls="mobile-navigation"
      aria-expanded="false"
      data-menu-button
    >
      <svg aria-hidden="true" class="menu-icon-open h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
      </svg>
      <svg aria-hidden="true" class="menu-icon-close h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 6l12 12M18 6 6 18" stroke-linecap="round" />
      </svg>
    </button>
  </div>
  <div
    id="mobile-navigation"
    class="mobile-menu overflow-hidden border-t border-zinc-200 bg-white/96 shadow-soft lg:hidden"
    aria-hidden="true"
    data-open="false"
    data-menu
  >
    <nav class="container-shell grid gap-1 py-4 text-sm text-zinc-700">
      {nav.map(([label, href]) => (
        <a class="focus-ring rounded-xl px-3 py-3 hover:bg-zinc-50 hover:text-zinc-950" href={href}>{label}</a>
      ))}
      {externalNav.map(([label, href]) => (
        <a
          class:list={[
            "focus-ring rounded-xl px-3 py-3 hover:bg-zinc-50",
            label === "Telegram Channel" ? "font-semibold text-xiaomi hover:bg-orange-50" : "hover:text-zinc-950",
          ]}
          href={href}
          target="_blank"
          rel="noreferrer"
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const menuButton = document.querySelector("[data-menu-button]");
  const menu = document.querySelector("[data-menu]");

  const setMenuState = (isOpen) => {
    menuButton?.setAttribute("aria-expanded", String(isOpen));
    menu?.setAttribute("aria-hidden", String(!isOpen));
    menu?.setAttribute("data-open", String(isOpen));
    document.body.classList.toggle("menu-open", isOpen);
  };

  menuButton?.addEventListener("click", () => {
    const isOpen = menuButton.getAttribute("aria-expanded") === "true";
    setMenuState(!isOpen);
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      setMenuState(false);
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setMenuState(false);
    }
  });

  window.matchMedia("(min-width: 1024px)").addEventListener("change", (event) => {
    if (event.matches) {
      setMenuState(false);
    }
  });
</script>

---
import campaigns from "../data/campaigns.json";

const { limit = 3 } = Astro.props;
const updates = campaigns
  .flatMap((campaign) =>
    campaign.updates.map((update) => ({
      ...update,
      campaignTitle: campaign.title,
      codename: campaign.codename,
    })),
  )
  .slice(0, limit);
---

<div class="grid gap-4 md:grid-cols-3">
  {updates.map((update) => (
    <article class="panel rounded-xl p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-xiaomi">
        {update.codename}
      </p>
      <h3 class="mt-3 text-lg font-semibold text-zinc-950">{update.title}</h3>
      <p class="mt-3 text-sm leading-6 text-zinc-600">{update.summary}</p>
      <p class="mt-4 text-xs text-zinc-500">{update.campaignTitle}</p>
    </article>
  ))}
</div>

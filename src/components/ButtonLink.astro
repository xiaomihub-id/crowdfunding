---
const {
  href,
  variant = "primary",
  target,
  rel,
} = Astro.props;

const baseClasses =
  "focus-ring inline-flex min-h-11 items-center justify-center rounded-xl px-4 py-2 text-sm font-semibold transition";
const variants = {
  primary: "bg-xiaomi text-white shadow-sm hover:bg-[#e95f00]",
  secondary:
    "border border-zinc-200 bg-white text-zinc-800 shadow-soft hover:border-xiaomi/50 hover:text-zinc-950",
  ghost: "text-zinc-600 hover:text-zinc-950",
};
---

<a
  href={href}
  class:list={[baseClasses, variants[variant]]}
  target={target}
  rel={rel}
>
  <slot />
</a>

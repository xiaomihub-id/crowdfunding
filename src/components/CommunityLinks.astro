---
import site from "../data/site.json";
import ButtonLink from "./ButtonLink.astro";
---

<section class="container-shell py-12">
  <div class="grid gap-4 md:grid-cols-[1.1fr_0.9fr] md:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Community Links</p>
      <h2 class="mt-3 text-2xl font-semibold text-white sm:text-3xl">Stay close to the project</h2>
      <p class="mt-3 max-w-2xl text-zinc-300">
        Follow XiaomiHub and XFI community spaces for campaign discussions, development updates, and public coordination.
      </p>
    </div>
    <div class="flex flex-wrap gap-3 md:justify-end">
      <ButtonLink href={site.githubUrl} variant="secondary" target="_blank" rel="noreferrer">GitHub</ButtonLink>
      <ButtonLink href={site.telegramUrl} target="_blank" rel="noreferrer">Telegram</ButtonLink>
    </div>
  </div>
</section>

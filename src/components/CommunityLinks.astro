---
import site from "../data/site.json";

const links = [
  {
    title: "Telegram Channel",
    purpose: "Announcements, crowdfunding updates, and official information from XiaomiHub | XFI.",
    cta: "Join Channel",
    href: site.telegramChannelUrl,
    type: "telegram",
  },
  {
    title: "Telegram Group",
    purpose: "Community discussions, maintainer communication, and supporter interaction.",
    cta: "Join Community Chat",
    href: site.telegramGroupUrl,
    type: "telegram",
  },
  {
    title: "GitHub Organization",
    purpose: "Open-source repositories, community archives, crowdfunding transparency, and Xiaomi ecosystem work.",
    cta: "View GitHub Organization",
    href: site.githubUrl,
    type: "github",
  },
];
---

<section id="community" class="container-shell scroll-mt-24 py-12 sm:py-14 lg:py-16">
  <div class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Community</p>
    <h2 class="mt-3 text-[clamp(1.75rem,5vw,2rem)] font-semibold leading-tight text-zinc-950">Join the Community</h2>
    <p class="mt-3 text-zinc-600">
      Stay connected with XiaomiHub | XFI community discussions, crowdfunding announcements, and ecosystem updates.
    </p>
  </div>

  <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {links.map((link) => (
      <article class="panel min-w-0 rounded-xl p-5">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl border border-xiaomi/25 bg-orange-50 text-xiaomi">
          {link.type === "telegram" ? (
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
              <path d="M21.7 4.4c.2-1-.7-1.7-1.6-1.3L2.9 9.7c-1 .4-1 1.8.1 2.1l4.4 1.4 1.7 5.4c.3.9 1.4 1.1 2 .4l2.5-2.6 4.6 3.4c.8.6 1.9.1 2.1-.9l3.4-14.5ZM8.1 12.3l8.5-5.2c.4-.2.8.3.5.6l-7 6.4-.3 3.1-1.1-3.7c-.1-.5-.3-.9-.6-1.2Z" />
            </svg>
          ) : (
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
              <path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.6.3-1.1.6-1.3-2.3-.3-4.7-1.2-4.7-5A3.9 3.9 0 0 1 6.4 8.8c-.1-.3-.4-1.3.1-2.7 0 0 .9-.3 2.8 1a9.7 9.7 0 0 1 5.2 0c1.9-1.3 2.8-1 2.8-1 .5 1.4.2 2.4.1 2.7a3.9 3.9 0 0 1 1 2.7c0 3.8-2.4 4.7-4.7 5 .4.3.7.9.7 1.8V21c0 .3.2.6.7.5A10 10 0 0 0 12 2Z" />
            </svg>
          )}
        </div>
        <h3 class="mt-5 text-lg font-semibold text-zinc-950">{link.title}</h3>
        <p class="mt-3 text-sm leading-6 text-zinc-600">{link.purpose}</p>
        <a
          class="focus-ring mt-5 inline-flex text-sm font-semibold text-xiaomi hover:text-[#e95f00]"
          href={link.href}
          target="_blank"
          rel="noreferrer"
        >
          {link.cta}
        </a>
      </article>
    ))}
  </div>
</section>

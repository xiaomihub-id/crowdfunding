---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ButtonLink from "../../components/ButtonLink.astro";
import campaigns from "../../data/campaigns.json";

export function getStaticPaths() {
  return campaigns.map((campaign) => ({
    params: { codename: campaign.codename },
    props: { campaign },
  }));
}

const { campaign } = Astro.props;
const formatter = new Intl.NumberFormat("id-ID", {
  style: "currency",
  currency: "IDR",
  maximumFractionDigits: 0,
});
const progress = Math.round((campaign.raised / campaign.target) * 1000) / 10;
---

<BaseLayout title={`${campaign.title} | XiaomiHub XFI`}>
  <section class="container-shell py-14">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.42fr]">
      <article>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">{campaign.status}</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-zinc-950 sm:text-5xl">{campaign.title}</h1>
        <p class="mt-4 max-w-3xl text-zinc-600">{campaign.description}</p>
        {campaign.purpose && (
          <p class="mt-4 max-w-3xl rounded-xl border border-zinc-200 bg-white p-4 text-sm leading-6 text-zinc-700 shadow-soft">
            {campaign.purpose}
          </p>
        )}

        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div class="panel rounded-xl p-5">
            <p class="text-xs text-zinc-500">Raised</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950">{formatter.format(campaign.raised)}</p>
          </div>
          <div class="panel rounded-xl p-5">
            <p class="text-xs text-zinc-500">Target</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950">{formatter.format(campaign.target)}</p>
          </div>
          <div class="panel rounded-xl p-5">
            <p class="text-xs text-zinc-500">Progress</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950">{progress}%</p>
          </div>
        </div>

        <section class="mt-10">
          <h2 class="text-2xl font-semibold text-zinc-950">Transparency updates</h2>
          <div class="mt-5 space-y-4">
            {campaign.archiveNote && (
              <article class="panel rounded-xl p-5">
                <h3 class="text-lg font-semibold text-zinc-950">Archive note</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-600">{campaign.archiveNote}</p>
              </article>
            )}
            {campaign.updates.map((update) => (
              <article class="panel rounded-xl p-5">
                <h3 class="text-lg font-semibold text-zinc-950">{update.title}</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-600">{update.summary}</p>
              </article>
            ))}
          </div>
        </section>

        {campaign.acknowledgement && (
          <section class="mt-10 rounded-xl border border-xiaomi/25 bg-orange-50 p-5">
            <h2 class="text-xl font-semibold text-zinc-950">Community acknowledgement</h2>
            <p class="mt-3 text-sm leading-6 text-zinc-700">{campaign.acknowledgement}</p>
          </section>
        )}

        <section class="mt-10">
          <h2 class="text-2xl font-semibold text-zinc-950">Contribution records</h2>
          <div class="mt-5 grid gap-4 md:grid-cols-2">
            {campaign.contributionChannels.map((channel) => (
              <article class="panel rounded-xl p-5">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-lg font-semibold text-zinc-950">{channel.name}</h3>
                  <p class="text-sm font-semibold text-xiaomi">
                    {formatter.format(channel.amount)}
                  </p>
                </div>
                {channel.foreignTotal && (
                  <p class="mt-1 text-xs text-zinc-500">{channel.foreignTotal}</p>
                )}
                <ul class="mt-4 space-y-2 text-sm text-zinc-600">
                  {channel.entries.map((entry) => <li>{entry}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>
      </article>

      <aside class="lg:sticky lg:top-24 lg:self-start">
        <div class="panel rounded-xl p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-xiaomi">Campaign Info</p>
          <dl class="mt-4 space-y-4 text-sm">
            <div>
              <dt class="text-zinc-500">Device</dt>
              <dd class="mt-1 text-zinc-950">{campaign.device}</dd>
            </div>
            <div>
              <dt class="text-zinc-500">Codename</dt>
              <dd class="mt-1 font-mono text-zinc-950">{campaign.codename}</dd>
            </div>
            <div>
              <dt class="text-zinc-500">Maintainer</dt>
              <dd class="mt-1 text-zinc-950">{campaign.maintainer}</dd>
            </div>
            <div>
              <dt class="text-zinc-500">Supporters</dt>
              <dd class="mt-1 text-zinc-950">{campaign.supporters}</dd>
            </div>
          </dl>
          <div class="mt-6 flex flex-col gap-3">
            {campaign.links.map((link) => (
              <ButtonLink href={link.url} variant="secondary" target="_blank" rel="noreferrer">
                {link.label}
              </ButtonLink>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

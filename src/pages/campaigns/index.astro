---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CampaignCard from "../../components/CampaignCard.astro";
import campaigns from "../../data/campaigns.json";

const sortedCampaigns = [...campaigns].sort((a, b) => Number(a.completed) - Number(b.completed));
const activeCampaigns = campaigns.filter((campaign) => !campaign.completed);
---

<BaseLayout title="Campaigns | XiaomiHub XFI">
  <section class="container-shell py-12 sm:py-14 lg:py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Campaigns</p>
    <h1 class="mt-4 text-[clamp(2.25rem,7vw,3.25rem)] font-bold leading-tight text-zinc-950">Community crowdfunding archive</h1>
    <p class="mt-4 max-w-3xl text-zinc-600">
      Active campaigns appear first. Completed campaigns remain available as permanent transparency records.
    </p>
    {activeCampaigns.length === 0 && (
      <div class="mt-8 rounded-xl border border-xiaomi/25 bg-orange-50 p-4 text-sm font-medium text-zinc-800">
        No active crowdfunding campaign at the moment.
      </div>
    )}
    <div class="mt-8 grid gap-5">
      {sortedCampaigns.map((campaign) => <CampaignCard campaign={campaign} featured />)}
    </div>
  </section>
</BaseLayout>

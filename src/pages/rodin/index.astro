---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ButtonLink from "../../components/ButtonLink.astro";
import campaigns from "../../data/campaigns.json";
import { basePath } from "../../utils/paths";

const campaign = campaigns.find((item) => item.codename === "rodin");
const formatter = new Intl.NumberFormat("id-ID", {
  style: "currency",
  currency: "IDR",
  maximumFractionDigits: 0,
});
---

<BaseLayout title="Rodin Campaign Archive | XiaomiHub XFI">
  <section class="container-shell py-12 sm:py-14 lg:py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Permanent Archive</p>
    <h1 class="mt-4 text-[clamp(2.25rem,7vw,3.25rem)] font-bold leading-tight text-zinc-950">POCO X7 Pro Crowdfunding - Rodin Alliance</h1>
    <p class="mt-4 max-w-3xl text-zinc-600">
      The original Rodin crowdfunding history is preserved here as a completed public transparency record.
    </p>

    <div class="mt-8 grid gap-5 lg:grid-cols-[0.8fr_1.2fr]">
      <aside class="panel rounded-xl p-5 lg:self-start">
        <p class="text-sm font-semibold text-xiaomi">Successfully Funded</p>
        <dl class="mt-4 space-y-4 text-sm">
          <div>
            <dt class="text-zinc-500">Goal</dt>
            <dd class="mt-1 text-xl font-semibold text-zinc-950">{formatter.format(campaign.target)}</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Raised</dt>
            <dd class="mt-1 text-xl font-semibold text-zinc-950">{formatter.format(campaign.raised)}</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Approx. USD</dt>
            <dd class="mt-1 text-zinc-950">{campaign.raisedApproxUsd} USD</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Result</dt>
            <dd class="mt-1 text-zinc-950">103.6% reached</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Maintainer</dt>
            <dd class="mt-1 text-zinc-950">{campaign.maintainer}</dd>
          </div>
        </dl>
        <div class="mt-6">
          <ButtonLink href={`${basePath}campaigns/rodin/`}>View Structured Campaign</ButtonLink>
        </div>
      </aside>

      <article class="space-y-5">
        <section class="panel rounded-xl p-5">
          <h2 class="text-2xl font-semibold text-zinc-950">Closure status</h2>
          <ul class="mt-4 space-y-2 text-sm text-zinc-600">
            <li>Collected contributions were fully returned to the developer.</li>
            <li>Contributions were used to purchase a POCO X7 Pro device.</li>
            <li>The device is actively being used for AOSP development.</li>
            <li>The crowdfunding process is completed according to its original purpose.</li>
          </ul>
        </section>

        <section class="panel rounded-xl p-5">
          <h2 class="text-2xl font-semibold text-zinc-950">Purpose</h2>
          <p class="mt-4 text-sm leading-6 text-zinc-600">{campaign.purpose}</p>
          <p class="mt-4 text-sm leading-6 text-zinc-600">{campaign.archiveNote}</p>
        </section>

        <section class="panel rounded-xl p-5">
          <h2 class="text-2xl font-semibold text-zinc-950">Contribution summary</h2>
          <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
            {campaign.contributionChannels.map((channel) => (
              <div class="min-w-0 rounded-xl border border-zinc-200 bg-zinc-50 p-4">
                <p class="font-semibold text-zinc-950">{channel.name}</p>
                <p class="mt-1 text-sm text-xiaomi">{formatter.format(channel.amount)}</p>
                {channel.foreignTotal && <p class="mt-1 text-xs text-zinc-500">{channel.foreignTotal}</p>}
              </div>
            ))}
          </div>
        </section>

        <section class="panel rounded-xl p-5">
          <h2 class="text-2xl font-semibold text-zinc-950">Original message</h2>
          <p class="mt-4 text-sm leading-6 text-zinc-600">
            This crowdfunding supported AOSP development for POCO X7 Pro with public contribution logging and regular updates. The archive remains available as a permanent record for transparency.
          </p>
          <p class="mt-4 text-sm leading-6 text-zinc-600">
            {campaign.acknowledgement}
          </p>
        </section>
      </article>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LatestUpdates from "../../components/LatestUpdates.astro";
---

<BaseLayout title="Updates | XiaomiHub XFI">
  <section class="container-shell py-12 sm:py-14 lg:py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Updates</p>
    <h1 class="mt-4 text-[clamp(2.25rem,7vw,3.25rem)] font-bold leading-tight text-zinc-950">Public campaign updates</h1>
    <p class="mt-4 max-w-3xl text-zinc-600">
      A lightweight feed of campaign milestones, transparency notes, and closure records.
    </p>
    <div class="mt-8">
      <LatestUpdates limit={12} />
    </div>
  </section>
</BaseLayout>

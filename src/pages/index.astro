---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import CampaignCard from "../components/CampaignCard.astro";
import CommunityLinks from "../components/CommunityLinks.astro";
import LatestUpdates from "../components/LatestUpdates.astro";
import XfiLogo from "../components/XfiLogo.astro";
import campaigns from "../data/campaigns.json";

const activeCampaigns = campaigns.filter((campaign) => !campaign.completed);
const featuredCampaign =
  activeCampaigns.find((campaign) => campaign.featured) ??
  campaigns.find((campaign) => campaign.codename === "rodin") ??
  campaigns[0];
---

<BaseLayout>
  <section class="container-shell grid gap-8 py-12 sm:py-14 lg:grid-cols-[1.04fr_0.96fr] lg:items-center lg:gap-12 lg:py-20 xl:py-24">
    <div class="text-center sm:text-left">
      <XfiLogo variant="main" class="mx-auto mb-7 hidden h-auto w-[min(260px,70vw)] sm:mx-0 md:block" />
      <XfiLogo variant="primary" class="mx-auto mb-6 h-auto w-[78px] sm:mx-0 md:hidden" alt="XFI" />
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-xiaomi">Community Crowdfunding</p>
      <h1 class="mx-auto mt-5 max-w-3xl text-[clamp(2.5rem,9vw,4rem)] font-extrabold leading-tight text-zinc-950 sm:mx-0 lg:text-[clamp(3.5rem,5vw,4.5rem)]">
        XiaomiHub | XFI
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg font-semibold leading-8 text-zinc-800 sm:mx-0 sm:text-xl">
        Community Crowdfunding Facilitation<br class="hidden sm:block" />
        for Xiaomi Device Development
      </p>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-zinc-600 sm:mx-0">
        Connecting maintainers and community supporters through transparent, community-first crowdfunding.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <ButtonLink href="campaigns/">View Campaigns</ButtonLink>
        <ButtonLink href="about/" variant="secondary">About XFI</ButtonLink>
      </div>
    </div>

    <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4">
      <p class="text-sm font-semibold text-xiaomi">
        {activeCampaigns.length ? "Featured active campaign" : "No active crowdfunding campaign at the moment."}
      </p>
      <div class="mt-4">
        <CampaignCard campaign={featuredCampaign} featured />
      </div>
    </div>
  </section>

  <section class="border-y border-zinc-200 bg-white py-12 sm:py-14 lg:py-16">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <XfiLogo variant="main" class="mb-6 h-auto w-[min(260px,80vw)]" />
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">About XFI</p>
        <h2 class="mt-3 text-[clamp(1.75rem,5vw,2rem)] font-semibold leading-tight text-zinc-950">A facilitator for community-backed development</h2>
      </div>
      <div class="space-y-4 text-zinc-600">
        <p>
          XiaomiHub | XFI helps facilitate transparent community crowdfunding to support Xiaomi device development and maintainer ecosystems.
        </p>
        <p>
          All crowdfunding contributions are fully returned to the maintainers or development teams responsible for managing the related device source and community projects.
        </p>
      </div>
    </div>
  </section>

  <section class="container-shell py-12 sm:py-14 lg:py-16">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Featured Campaign</p>
        <h2 class="mt-3 text-[clamp(1.75rem,5vw,2rem)] font-semibold leading-tight text-zinc-950">Current community focus</h2>
      </div>
      <ButtonLink href="campaigns/" variant="secondary">All Campaigns</ButtonLink>
    </div>
    <CampaignCard campaign={featuredCampaign} featured />
  </section>

  <section class="border-y border-zinc-200 bg-white py-12 sm:py-14 lg:py-16">
    <div class="container-shell">
      <div class="mb-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Latest Updates</p>
        <h2 class="mt-3 text-[clamp(1.75rem,5vw,2rem)] font-semibold leading-tight text-zinc-950">Public campaign notes</h2>
      </div>
      <LatestUpdates />
    </div>
  </section>

  <CommunityLinks />

  <section class="container-shell pb-12 sm:pb-16 lg:pb-20">
    <div class="panel rounded-xl p-6 md:p-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-xiaomi">Transparency</p>
          <h2 class="mt-3 text-[clamp(1.75rem,5vw,2rem)] font-semibold leading-tight text-zinc-950">Facilitation, not profit</h2>
        </div>
        <XfiLogo variant="main" class="h-auto w-[min(220px,70vw)] opacity-95" />
      </div>
      <div class="mt-5 grid gap-4 text-sm leading-6 text-zinc-600 sm:grid-cols-2 lg:grid-cols-3">
        <p>XFI acts as a bridge between maintainers, developers, device communities, and supporters.</p>
        <p>Campaign contributions are intended for the related maintainer, development team, device source, or community project.</p>
        <p>Community trust is prioritized through visible records, clear campaign context, and preserved historical archives.</p>
      </div>
    </div>
  </section>
</BaseLayout>
